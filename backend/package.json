{
  "name": "quant-entelloq-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Quant Entelloq backend — AI-native financial intelligence platform",
  "engines": { "node": ">=20.0.0" },
  "scripts": {
    "dev":         "nodemon server.js",
    "start":       "node server.js",
    "worker":      "node worker.js",
    "migrate":     "node db/migrate.js",
    "seed":        "node db/seed.js",
    "test":        "vitest run",
    "test:watch":  "vitest",
    "lint":        "eslint . --ext .js",
    "fmt":         "prettier --write \"**/*.{js,json,md}\""
  },
  "dependencies": {
    "express":              "^4.19.2",
    "helmet":               "^7.1.0",
    "cors":                 "^2.8.5",
    "compression":          "^1.7.4",
    "cookie-parser":        "^1.4.6",
    "express-rate-limit":   "^7.2.0",
    "bcryptjs":             "^2.4.3",
    "jsonwebtoken":         "^9.0.2",
    "joi":                  "^17.13.0",
    "winston":              "^3.13.0",
    "pino":                 "^9.1.0",
    "pino-pretty":          "^11.0.0",
    "dotenv":               "^16.4.5",
    "node-fetch":           "^3.3.2",
    "p-retry":              "^6.2.0",
    "p-queue":              "^8.0.1",
    "rss-parser":           "^3.13.0",
    "node-cron":            "^3.0.3",
    "bullmq":               "^5.7.0",
    "ioredis":              "^5.4.1",
    "pg":                   "^8.11.5",
    "ws":                   "^8.17.0",
    "socket.io":            "^4.7.5",
    "@sentry/node":         "^8.7.0",
    "uuid":                 "^9.0.1",
    "google-auth-library":  "^9.10.0"
  },
  "devDependencies": {
    "nodemon":  "^3.1.0",
    "vitest":   "^1.6.0",
    "supertest":"^7.0.0",
    "eslint":   "^9.3.0",
    "prettier": "^3.2.5"
  }
}
