# ============================================================
# Quant Entelloq Backend — Environment Variables
# Copy to .env and fill in the values you need.
# ============================================================

# --- Runtime ---
NODE_ENV=production
PORT=4000
APP_URL=https://quant.entelloq.com
ALLOWED_ORIGINS=https://quant.entelloq.com,https://www.quant.entelloq.com
RUN_PIPELINES_INLINE=false       # true on small deployments; false if you run worker.js separately

# --- Postgres ---
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/quant_entelloq
DATABASE_SSL=require              # 'disable' for local docker, 'require' for managed Postgres

# --- Redis (BullMQ + cache) ---
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# --- JWT / Sessions ---
# MUST be a 64-char random hex string in production. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-me-with-64-char-random-hex
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
COOKIE_SECRET=replace-me-with-32-char-random-hex
COOKIE_DOMAIN=.entelloq.com       # blank for localhost

# --- AI provider abstraction ---
# Selects which backend handles /api/ai/* — groq | openai | anthropic | together
AI_PROVIDER=groq
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
AI_MODEL_STREAM=                  # optional override (default per provider)
AI_MODEL_CALL=                    # optional override (default per provider)
AI_REWRITE_MODEL=                 # model used by news rewriter (defaults to AI_MODEL_CALL)
AI_MAX_TOKENS=2000

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Market data (Massive / Polygon) ---
MASSIVE_API_KEY=
POLYGON_API_KEY=                  # legacy alias; reads MASSIVE_API_KEY first
FMP_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=

# --- Monitoring ---
SENTRY_DSN=
LOG_LEVEL=info                    # trace|debug|info|warn|error|fatal

# --- Free tier limits ---
FREE_TIER_DAILY_AI_LIMIT=20
FREE_TIER_DAILY_DISCOVER_LIMIT=50
