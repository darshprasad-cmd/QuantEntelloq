# Node scripts used during frontend development
*.js
!backend/**/*.js
!backend/**/*.cjs
# Production app bundle: app.js = readable source, app.min.js = served (minified).
# Re-minify after editing app.js:  npx terser js/app.js -c -m --comments false -o js/app.min.js
!js/*.js

# Dependencies + build artifacts
node_modules/
backend/node_modules/
backend/dist/
backend/coverage/
backend/.env
backend/.env.local

# OS files
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp
.idea/
